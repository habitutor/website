{
  "name": "habitutor",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "hono": "^4.12.11",
      "@orpc/server": "^1.13.13",
      "@orpc/openapi": "^1.13.13",
      "@orpc/arktype": "^1.13.13",
      "better-auth": "^1.5.6",
      "dotenv": "^17.4.1",
      "drizzle-orm": "^0.45.2",
      "drizzle-arktype": "^0.1.3",
      "arktype": "^2.2.0",
      "typescript": "^6.0.2",
      "midtrans-client": "^1.4.3",
      "tsdown": "^0.21.7",
      "@orpc/client": "^1.13.13"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint --fix . && oxfmt --write .",
    "lint:linter": "oxlint .",
    "lint:formatter": "oxfmt --check .",
    "dev": "turbo dev",
    "start": "turbo start",
    "build": "turbo build",
    "build:packages": "turbo build --filter='./packages/*'",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @habitutor/db db:push",
    "db:studio": "turbo -F @habitutor/db db:studio",
    "db:generate": "turbo -F @habitutor/db db:generate",
    "db:migrate": "turbo -F @habitutor/db db:migrate",
    "db:start": "turbo -F @habitutor/db db:start",
    "db:watch": "turbo -F @habitutor/db db:watch",
    "db:stop": "turbo -F @habitutor/db db:stop",
    "db:down": "turbo -F @habitutor/db db:down",
    "db:seed": "turbo -F @habitutor/db db:seed",
    "db:reset": "turbo -F @habitutor/db db:reset",
    "auth:generate": "turbo -F @habitutor/auth auth:generate",
    "test": "turbo test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "shadcn": "^4.1.2",
    "turbo": "^2.9.4"
  },
  "packageManager": "bun@1.3.5"
}
