{
	"name": "@habitutor/api",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./*": {
			"types": "./dist/*.d.mts",
			"default": "./dist/*.mjs"
		}
	},
	"imports": {
		"#index": "./src/index.ts",
		"#*": [
			"./src/*.ts",
			"./src/*/index.ts"
		],
		"#lib/*": "./src/lib/*.ts",
		"#utils/*": "./src/utils/*.ts",
		"#types/*": "./src/types/*.ts",
		"#routers/*": [
			"./src/routers/*.ts",
			"./src/routers/*/index.ts"
		],
		"#routers/admin/*": [
			"./src/routers/admin/*.ts",
			"./src/routers/admin/*/index.ts"
		],
		"#middlewares/*": "./src/middlewares/*.ts",
		"#__tests__/*": "./src/__tests__/*.ts"
	},
	"type": "module",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsgo --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch"
	},
	"devDependencies": {
		"@habitutor/config": "workspace:*",
		"@types/midtrans-client": "^1.4.0",
		"tsdown": "catalog:"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@orpc/server": "catalog:",
		"@orpc/client": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/arktype": "catalog:",
		"drizzle-orm": "catalog:",
		"hono": "catalog:",
		"dotenv": "catalog:",
		"arktype": "catalog:",
		"midtrans-client": "catalog:",
		"@habitutor/auth": "workspace:*",
		"@habitutor/db": "workspace:*"
	}
}
