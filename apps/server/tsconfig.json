{
  "extends": "@habitutor/config/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "composite": true,
    "outDir": "dist",
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./src/*"],
      "*": ["./*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "include": ["src/**/*", "../../packages/shared/src/types/midtrans-client.d.ts"]
}
