{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "bun build --production --target=bun --minify --sourcemap --bytecode ./src/index.ts --outdir ./dist",
    "build:local": "bun build --target=bun --minify --sourcemap --bytecode ./src/index.ts --outdir ./dist",
    "compile": "bun build --production --compile --minify --sourcemap --bytecode ./src/index.ts --outfile ./bin/server",
    "dev": "bun run --hot --port=3001 ./src/index.ts ",
    "start": "bun ./dist/index.js",
    "check-types": "tsgo --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@habitutor/api": "workspace:*",
    "@habitutor/auth": "workspace:*",
    "@habitutor/shared": "workspace:*",
    "@orpc/arktype": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@habitutor/config": "workspace:*",
    "@types/bun": "latest",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
